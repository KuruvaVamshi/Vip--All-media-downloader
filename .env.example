# Render Secret File path for exported YouTube cookies.
# Create a Secret File in Render named youtube-cookies.txt, then set this env var:
YTDLP_COOKIES_FILE=/etc/secrets/youtube-cookies.txt

# Alternative: paste base64 encoded cookies instead of using a Secret File.
# YTDLP_COOKIES_BASE64=

# Alternative: paste raw Netscape cookies text. Keep real values out of Git.
# YTDLP_COOKIES_CONTENT=
